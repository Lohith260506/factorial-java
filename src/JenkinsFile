pipeline {
    agent any
    stages {
        stage('Fetch Code') {
            steps {
                git 'https://github.com'
            }
        }
        stage('Build') {
            steps {
                sh 'mvn clean compile'
            }
        }
        stage('Run Tests') {
            steps {
                sh 'mvn test'
            }
        }
    }
}
